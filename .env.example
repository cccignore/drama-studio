# 必填：用于加密 LLM api_key 的主密钥（32 字节 hex，openssl rand -hex 32）
APP_SECRET=change-me-to-a-32-byte-hex-string-please-0000

# 可选：站点外显 URL
APP_URL=http://localhost:3000

# 可选：日志等级
LOG_LEVEL=info

# 可选：部署时自动初始化一把默认 LLM 配置（留空则 UI 手动添加）
DEFAULT_LLM_NAME=DeepSeek
DEFAULT_LLM_PROTOCOL=openai
DEFAULT_LLM_BASE_URL=https://api.deepseek.com/v1
DEFAULT_LLM_MODEL=deepseek-chat
DEFAULT_LLM_API_KEY=

# 云雾一站式网关（可选，填了会自动预置 GPT-5.4 / DeepSeek / Grok 三条模型）
YUNWU_API_KEY=
YUNWU_BASE_URL=https://api.yunwu.ai/v1
